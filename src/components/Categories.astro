---
const categories = [
  { name: "Plushies", image: "https://placehold.co/400x400/FFB6C1/000000?text=Plushies" },
  { name: "Essentials", image: "https://placehold.co/400x400/98FF98/000000?text=Essentials" },
  { name: "Unique Finds", image: "https://placehold.co/400x400/E5E7EB/000000?text=Unique+Finds" },
  { name: "Cute Bags", image: "https://placehold.co/400x400/F3E8FF/000000?text=Cute+Bags" },
];
---

<section class="py-12 md:py-24 bg-stone-100/50">
  <div class="container mx-auto px-4">
    <div class="space-y-12">
      <div class="text-center md:text-left">
        <h2 class="text-3xl md:text-5xl text-charcoal">Explore Our Collections</h2>
        <p class="text-stone-500 mt-4">Curated with love for your special ones.</p>
      </div>

      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 md:gap-8">
        {categories.map((category) => (
          <div class="group cursor-pointer">
            <div class="bg-white p-2 rounded-[40px] shadow-sm group-hover:shadow-md transition-all duration-300">
              <div class="aspect-square overflow-hidden rounded-[32px]">
                <img 
                  src={category.image} 
                  alt={category.name} 
                  class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500"
                />
              </div>
              <div class="py-4 text-center">
                <span class="font-bold text-sm md:text-base tracking-wide uppercase text-charcoal">
                  {category.name}
                </span>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
