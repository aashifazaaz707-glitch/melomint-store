---
const categories = [
  { name: "Premium Plushies", image: "https://pub-82aee35f0f1e41a5a2d6ffec8860f5a2.r2.dev/file_0000000037e87208a141fc6b805969fa.png" },
  { name: "Dining & Glass", image: "https://pub-82aee35f0f1e41a5a2d6ffec8860f5a2.r2.dev/file_0000000034bc72089f2a2de7b687ae08.png" },
  { name: "Designer Purses", image: "https://pub-82aee35f0f1e41a5a2d6ffec8860f5a2.r2.dev/file_00000000525c7208b7439178b6bf753a.png" },
  { name: "Kids Collection", image: "https://pub-82aee35f0f1e41a5a2d6ffec8860f5a2.r2.dev/file_00000000d5787208ad045d50eb762af0.png" },
];
---

<section class="py-12 md:py-24 bg-stone-100/50">
  <div class="container mx-auto px-4">
    <div class="space-y-12">
      <div class="text-center md:text-left">
        <h2 class="text-3xl md:text-5xl text-charcoal">Explore Our Collections</h2>
        <p class="text-stone-500 mt-4">Curated with love for your special ones.</p>
      </div>

      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 md:gap-8">
        {categories.map((category) => (
          <div class="group cursor-pointer">
            <div class="bg-white p-2 rounded-[40px] shadow-sm group-hover:shadow-md transition-all duration-300">
              <div class="aspect-square overflow-hidden rounded-[32px]">
                <img 
                  src={category.image} 
                  alt={category.name} 
                  class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500"
                />
              </div>
              <div class="py-4 text-center">
                <span class="font-bold text-sm md:text-base tracking-wide uppercase text-charcoal">
                  {category.name}
                </span>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
