<section class="py-12 md:py-24">
  <div class="container mx-auto px-4">
    <div class="flex flex-col md:flex-row items-center gap-12 md:gap-20">
      <div class="w-full md:w-1/2 space-y-8 text-center md:text-left">
        <h1 class="text-4xl md:text-7xl leading-[1.1] text-charcoal">
          Welcome to MeloMint: A World Full of <span class="text-emerald-400">Cute Finds ✨</span>.
        </h1>
        <p class="text-lg md:text-xl text-stone-500 max-w-lg mx-auto md:mx-0">
