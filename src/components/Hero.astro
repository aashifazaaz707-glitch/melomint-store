---
---

<section class="relative min-h-[90vh] flex items-center overflow-hidden pt-32 pb-12 md:pt-48 md:pb-24">
  {/* Video Background Layer */}
  <div class="absolute inset-0 z-0">
    <video 
      autoplay 
      muted 
      loop 
      playsinline 
      class="w-full h-full object-cover opacity-30"
    >
      <source src="https://d8j0ntlcm91z4.cloudfront.net/user_38xzZboKViGWJOttwIXH07lWA1P/hf_20260419_065931_e3ca7b53-d32e-4ad5-81de-dc9d6fcfda6d.mp4" type="video/mp4" />
    </video>
    {/* Soft Gradient Overlay for depth */}
    <div class="absolute inset-0 bg-gradient-to-b from-cream/80 via-transparent to-cream/80"></div>
  </div>

  <div class="container mx-auto px-4 relative z-10">
    <div class="flex flex-col md:flex-row items-center gap-12 md:gap-20">
      <div class="w-full md:w-1/2 space-y-8 text-center md:text-left">
        <h1 class="text-4xl md:text-7xl leading-[1.1] text-charcoal">
          Welcome to MeloMint: A World Full of <span class="text-emerald-400">Cute Finds ✨</span>.
        </h1>
        <p class="text-lg md:text-xl text-stone-600 max-w-lg mx-auto md:mx-0 font-medium">
          Direct from our Darbhanga store to your doorstep. Explore a curated collection of premium gifts that bring joy to every corner.
        </p>
        <div class="pt-4">
          <a 
            href="https://wa.me/919939511629?text=Hi%20MeloMint!%20I'd%20like%20to%20place%20an%20order." 
            target="_blank"
            class="group inline-flex items-center gap-4 px-10 h-16 bg-emerald-300 text-charcoal font-bold text-sm uppercase tracking-[0.2em] rounded-full shadow-[0_20px_40px_-15px_rgba(110,231,183,0.6)] hover:shadow-[0_25px_50px_-12px_rgba(110,231,183,0.7)] hover:-translate-y-1 active:scale-90 transition-all duration-500 border-2 border-white"
          >
            <span>WhatsApp to Order</span>
            <div class="w-8 h-8 rounded-full bg-white/40 flex items-center justify-center group-hover:bg-white transition-colors duration-500">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="group-hover:translate-x-0.5 transition-transform"><path d="M5 12h14m-7-7 7 7-7 7"/></svg>
            </div>
          </a>
        </div>
      </div>
      <div class="w-full md:w-1/2">
        <div class="relative group">
          <div class="absolute inset-0 bg-secondary rounded-boutique -rotate-3 transition-transform group-hover:rotate-0 duration-500 -z-10 opacity-50"></div>
          <img 
            src="https://pub-82aee35f0f1e41a5a2d6ffec8860f5a2.r2.dev/file_0000000069e07208b2a3872024f86101.png" 
            alt="MeloMint Premium Store Interior" 
            class="w-full h-auto rounded-boutique shadow-2xl object-cover aspect-square md:aspect-auto md:h-[600px] border-4 border-white"
          />
        </div>
      </div>
    </div>
  </div>
</section>
