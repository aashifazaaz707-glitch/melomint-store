          <div class="absolute inset-0 bg-secondary rounded-boutique -rotate-3 transition-transform group-hover:rotate-0 duration-500 -z-10"></div>
          <img 
            src="https://pub-82aee35f0f1e41a5a2d6ffec8860f5a2.r2.dev/file_0000000069e07208b2a3872024f86101.png" 
            alt="MeloMint Premium Store Interior" 
            class="w-full h-auto rounded-boutique shadow-lg object-cover aspect-square md:aspect-auto md:h-[600px]"
          />
        </div>
      </div>
    </div>
