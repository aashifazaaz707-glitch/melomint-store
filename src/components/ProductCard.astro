---
interface Props {
  name: string;
  price: string;
  image: string;
}

const { name, price, image } = Astro.props;
---

<article class="bg-white rounded-[40px] p-3 shadow-boutique group flex flex-col h-full">
  <div class="aspect-[3/4] overflow-hidden rounded-[32px] bg-stone-50 mb-4">
    <img 
      src={image} 
      alt={name} 
      class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700 ease-out"
    />
  </div>
  
  <div class="px-2 space-y-1 mb-6">
    <h3 class="text-lg md:text-xl font-sans font-medium text-charcoal">{name}</h3>
    <p class="text-primary font-bold text-lg">{price}</p>
  </div>

  <div class="mt-auto pt-6">
    <a 
      href={`https://wa.me/919939511629?text=Hi%20MeloMint!%20I'm%20interested%20in%20the%20${encodeURIComponent(name)}.`}
      target="_blank"
      class="group relative flex items-center justify-center w-full h-12 bg-emerald-300 text-charcoal font-bold text-[10px] uppercase tracking-[0.2em] rounded-full overflow-hidden border-2 border-emerald-300 shadow-sm transition-all duration-500 hover:shadow-[0_10px_20px_-5px_rgba(110,231,183,0.4)] hover:-translate-y-0.5 active:scale-95"
    >
      <div class="relative z-10 flex items-center gap-3">
        <span>Tap to Order</span>
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="translate-x-0 group-hover:translate-x-2 transition-transform duration-500"><path d="M5 12h14m-7-7 7 7-7 7"/></svg>
      </div>
    </a>
  </div>
</article>
