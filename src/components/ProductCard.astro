---
interface Props {
  name: string;
  price: string;
  image: string;
}

const { name, price, image } = Astro.props;
---

<article class="bg-white rounded-[40px] p-3 shadow-boutique group flex flex-col h-full">
  <div class="aspect-[3/4] overflow-hidden rounded-[32px] bg-stone-50 mb-4">
    <img 
      src={image} 
      alt={name} 
      class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700 ease-out"
    />
  </div>
  
  <div class="px-2 space-y-1 mb-6">
    <h3 class="text-lg md:text-xl font-sans font-medium text-charcoal">{name}</h3>
    <p class="text-primary font-bold text-lg">{price}</p>
  </div>

  <div class="mt-auto">
    <a 
      href={`https://wa.me/1234567890?text=Hi%20MeloMint!%20I'm%20interested%20in%20the%20${encodeURIComponent(name)}.`}
      target="_blank"
      class="flex items-center justify-center w-full h-12 md:h-14 bg-emerald-100 text-charcoal font-bold text-sm uppercase tracking-widest rounded-full hover:bg-primary active:scale-95 transition-all duration-300"
    >
      Tap to Order
    </a>
  </div>
</article>
