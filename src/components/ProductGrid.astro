---
import ProductCard from "./ProductCard.astro";

const products = [
  { name: "Pastel Trifold Wallet", price: "₹499", image: "https://placehold.co/500x600/E5E7EB/000000?text=Wallet" },
  { name: "Fluffy Bunny Plushie", price: "₹899", image: "https://placehold.co/500x600/FFB6C1/000000?text=Plushie" },
  { name: "Minimalist Tote Bag", price: "₹1,299", image: "https://placehold.co/500x600/F3E8FF/000000?text=Tote" },
  { name: "Aesthetic Desk Lamp", price: "₹1,599", image: "https://placehold.co/500x600/98FF98/000000?text=Lamp" },
  { name: "Cute Ceramic Mug", price: "₹349", image: "https://placehold.co/500x600/E4E2DE/000000?text=Mug" },
  { name: "Soft Grip Pens Set", price: "₹199", image: "https://placehold.co/500x600/FEF9C3/000000?text=Pens" },
];
---

<section class="py-12 md:py-24">
  <div class="container mx-auto px-4">
    <div class="space-y-12">
      <div class="text-center md:text-left flex flex-col md:flex-row md:items-end justify-between gap-6">
        <div class="space-y-2">
          <h2 class="text-3xl md:text-5xl text-charcoal tracking-tight">New Drops & Best Sellers</h2>
          <p class="text-stone-500">Handpicked items that you'll fall in love with.</p>
        </div>
        <div>
          <span class="inline-block px-6 py-2 bg-rose-50 text-rose-400 font-bold rounded-full text-sm uppercase tracking-widest">
            Fresh Arrival
          </span>
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {products.map((product) => (
          <ProductCard {...product} />
        ))}
      </div>
    </div>
  </div>
</section>
