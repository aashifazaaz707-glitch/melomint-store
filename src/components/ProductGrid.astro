---
import ProductCard from "./ProductCard.astro";

const products = [
  { name: "Elegant Pastel Wallet", price: "₹499", image: "https://pub-82aee35f0f1e41a5a2d6ffec8860f5a2.r2.dev/file_000000008db472089e247c37af1da4a5.png" },
  { name: "Premium Travel Trolley", price: "₹3,499", image: "https://pub-82aee35f0f1e41a5a2d6ffec8860f5a2.r2.dev/file_0000000033d87208b62176740d34974d.png" },
  { name: "Luxury Designer Purse", price: "₹1,899", image: "https://pub-82aee35f0f1e41a5a2d6ffec8860f5a2.r2.dev/file_00000000525c7208b7439178b6bf753a.png" },
  { name: "Artisanal Glass Set", price: "₹899", image: "https://pub-82aee35f0f1e41a5a2d6ffec8860f5a2.r2.dev/file_0000000034bc72089f2a2de7b687ae08.png" },
  { name: "Cute Kids Backpack", price: "₹1,299", image: "https://pub-82aee35f0f1e41a5a2d6ffec8860f5a2.r2.dev/file_00000000d5787208ad045d50eb762af0.png" },
  { name: "Cuddly Jumbo Teddy", price: "₹1,599", image: "https://pub-82aee35f0f1e41a5a2d6ffec8860f5a2.r2.dev/file_0000000037e87208a141fc6b805969fa.png" },
];
---

<section class="py-12 md:py-24">
  <div class="container mx-auto px-4">
    <div class="space-y-12">
      <div class="text-center md:text-left flex flex-col md:flex-row md:items-end justify-between gap-6">
        <div class="space-y-2 reveal-section">
          <h2 class="text-4xl md:text-6xl text-charcoal font-script leading-tight">New Drops & Best Sellers</h2>
          <p class="text-stone-500 font-medium transition-all duration-1000 ease-out handpicked-text">
            <span class="relative inline-block px-1">
              Handpicked
              <span class="absolute bottom-1 left-0 w-0 h-[30%] bg-emerald-200/50 -z-10 highlight-draw transition-all duration-1000 delay-500 ease-out"></span>
            </span>
            items that you'll fall in love with.
          </p>
        </div>
        <div class="relative badge-float inline-block">
          <span class="inline-block px-6 md:px-8 py-2 bg-rose-50 text-rose-800 font-script text-2xl md:text-3xl rounded-full shadow-sm border border-rose-100/50">
            Fresh Arrival
          </span>
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {products.map((product) => (
          <ProductCard {...product} />
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .font-script {
    font-family: 'Dancing Script', cursive;
  }

  .badge-float {
    animation: float-soft 3s ease-in-out infinite;
  }

  @keyframes float-soft {
    0%, 100% { transform: translateY(0) rotate(0); }
    50% { transform: translateY(-10px) rotate(2deg); }
  }

  .handpicked-text {
    opacity: 0;
    transform: translateY(20px);
  }

  .reveal-section.active .handpicked-text {
    opacity: 1;
    transform: translateY(0);
  }

  .reveal-section.active .highlight-draw {
    width: 100%;
  }
</style>

<script>
  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) {
        entry.target.classList.add('active');
      }
    });
  }, { threshold: 0.1 });

  document.querySelectorAll('.reveal-section').forEach((el) => observer.observe(el));
</script>
